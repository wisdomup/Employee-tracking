{
  "name": "wisdomup-express",
  "version": "1.0.0",
  "description": "Wisdomup API — Express.js rewrite",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "migrate:fix-task-ids": "ts-node src/database/migrations/fix-task-ids.ts",
    "migrate:fix-taskid-types": "ts-node src/database/migrations/fix-taskid-types.ts",
    "migrate:update-assignment-status": "ts-node src/database/migrations/update-assignment-status.ts",
    "migrate:route-text-fields": "ts-node src/database/migrations/route-text-fields.ts",
    "migrate:task-default-route": "ts-node src/database/migrations/task-default-route.ts",
    "migrate:update-admin-email": "ts-node src/database/migrations/update-admin-email.ts",
    "seed:admin": "ts-node src/database/seeds/admin.seed.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^6.4.15",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
