PORT=8001
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gps_task_tracking
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=24h
UPLOAD_PATH=./uploads

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FRONTEND_URL=http://localhost:5001

# Daily visit generation at start of day (routes with assigned employee + dealers)
# VISIT_CRON_ENABLED=false
# Midnight in the timezone below; omit Friday (0,1,2,3,4,6 = Sun–Thu and Sat)
# VISIT_CRON_SCHEDULE=0 0 * * 0,1,2,3,4,6
# VISIT_CRON_TIMEZONE=UTC
# Optional testing only: if VISIT_CRON_SCHEDULE is unset, daily at server start + N minutes
# VISIT_CRON_STARTUP_OFFSET_MINUTES=7
